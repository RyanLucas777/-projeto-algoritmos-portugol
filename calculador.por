Configuração inicial da estrutura do algoritmo em Portugol
programa

{
    funcao inicio()
    {
       
        real numero1, numero2, resultado
        caracter operacao

    
        escreva("Digite o primeiro número: ")
        leia(numero1)

        escreva("Digite a operação (+, -, *, /): ")
        leia(operacao)

        escreva("Digite o segundo número: ")
        leia(numero2)

     
    }
}
